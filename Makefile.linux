CC = clang
CFLAGS = -Wall -Wextra -O2
TARGETS = rawcc raw-runtime

PREFIX = /usr/local

all: $(TARGETS)

rawcc: cc.c
	$(CC) $(CFLAGS) -o $@ cc.c

raw-runtime: runtime.c
	$(CC) $(CFLAGS) -o $@ runtime.c reg-memory.c func-space.c

install: $(TARGETS)
	install -d $(DESTDIR)$(PREFIX)/bin
	install -m 755 rawcc $(DESTDIR)$(PREFIX)/bin/rawcc
	install -m 755 raw-runtime $(DESTDIR)$(PREFIX)/bin/raw-runtime

clean:
	rm -f $(TARGETS)

.PHONY: all install clean
